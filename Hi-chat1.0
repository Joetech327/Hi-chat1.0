<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hi-Chat — Chat like it's 3025</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }
        
        /* Custom scrollbar styling */
        ::-webkit-scrollbar {
            width: 8px;
        }
        
        ::-webkit-scrollbar-track {
            background: #0a0a0a;
        }
        
        ::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 4px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: #555;
        }
        
        /* Firefox scrollbar */
        html {
            scrollbar-width: thin;
            scrollbar-color: #333 #0a0a0a;
        }
        
        body {
            overflow-x: hidden;
            overflow-y: auto;
        }
        
        .glass-panel {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        
        .gradient-text {
            background: linear-gradient(135deg, #fff 0%, #a5a5a5 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .glow {
            box-shadow: 0 0 60px rgba(255, 255, 255, 0.1);
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        
        .animate-float {
            animation: float 6s ease-in-out infinite;
        }
        
        @keyframes pulse-glow {
            0%, 100% { opacity: 0.4; }
            50% { opacity: 0.8; }
        }
        
        .animate-pulse-glow {
            animation: pulse-glow 3s ease-in-out infinite;
        }
        
        .chat-bubble {
            position: relative;
        }
        
        .chat-bubble::before {
            content: '';
            position: absolute;
            inset: -1px;
            border-radius: inherit;
            padding: 1px;
            background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
        }
    </style>
</head>
<body class="bg-[#0a0a0a] text-white min-h-screen">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-panel border-b border-white/5">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center">
                    <i data-lucide="message-circle" class="w-5 h-5 text-black"></i>
                </div>
                <span class="font-bold text-xl tracking-tight">Hi-Chat</span>
            </div>
            <div class="hidden md:flex items-center gap-8 text-sm text-gray-400">
                <a href="#features" class="hover:text-white transition-colors">Features</a>
                <a href="#privacy" class="hover:text-white transition-colors">Privacy</a>
                <a href="#download" class="hover:text-white transition-colors">Download</a>
            </div>
            <button class="bg-white text-black px-5 py-2 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
                Get Started
            </button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden">
        <!-- Background glow -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-white/5 rounded-full blur-[120px] animate-pulse-glow"></div>
        
        <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
            <div class="inline-flex items-center gap-2 glass-panel px-4 py-2 rounded-full mb-8 animate-float">
                <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
                <span class="text-sm text-gray-300">Live video status • Mood-based chat</span>
            </div>
            
            <h1 class="text-5xl md:text-7xl lg:text-8xl font-black tracking-tighter mb-6 leading-[0.9]">
                <span class="gradient-text">Chat like it's</span><br>
                <span class="text-white">3025</span>
            </h1>
            
            <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-12 leading-relaxed">
                Live video status. Mood-based chat. Ghost mode when you need it.
            </p>
            
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <button class="bg-white text-black px-8 py-4 rounded-full font-semibold text-lg hover:bg-gray-200 transition-all hover:scale-105 flex items-center gap-2">
                    <i data-lucide="download" class="w-5 h-5"></i>
                    Download for iOS
                </button>
                <button class="glass-panel px-8 py-4 rounded-full font-semibold text-lg hover:bg-white/10 transition-all flex items-center gap-2">
                    <i data-lucide="globe" class="w-5 h-5"></i>
                    Use on Web
                </button>
            </div>
        </div>
        
        <!-- Floating elements -->
        <div class="absolute bottom-20 left-10 glass-panel p-4 rounded-2xl animate-float hidden lg:block" style="animation-delay: 1s;">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full"></div>
                <div>
                    <div class="text-sm font-medium">Sarah is live</div>
                    <div class="text-xs text-gray-400">2.4k watching</div>
                </div>
            </div>
        </div>
        
        <div class="absolute top-40 right-10 glass-panel p-4 rounded-2xl animate-float hidden lg:block" style="animation-delay: 2s;">
            <div class="flex items-center gap-2 text-sm">
                <i data-lucide="ghost" class="w-4 h-4 text-purple-400"></i>
                <span class="text-gray-300">Ghost mode active</span>
            </div>
        </div>
    </section>

    <!-- Live Stream Section -->
    <section id="features" class="py-32 relative">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div class="relative">
                    <div class="aspect-[4/3] rounded-3xl overflow-hidden glass-panel glow">
                        <img src="https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?w=800&h=600&fit=crop" 
                             alt="Concert live stream" 
                             class="w-full h-full object-cover opacity-80">
                        <div class="absolute top-4 left-4 bg-red-500 text-white px-3 py-1 rounded-full text-sm font-medium flex items-center gap-2">
                            <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
                            LIVE
                        </div>
                        <div class="absolute bottom-4 left-4 right-4">
                            <div class="glass-panel rounded-2xl p-4 flex items-center gap-4">
                                <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face" 
                                     alt="Streamer" 
                                     class="w-12 h-12 rounded-full object-cover">
                                <div class="flex-1">
                                    <div class="font-semibold">Joseph Bassey</div>
                                    <div class="text-sm text-gray-400">2.4k watching</div>
                                </div>
                                <button class="bg-white text-black px-4 py-2 rounded-full text-sm font-medium">
                                    Watch
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div>
                    <h2 class="text-4xl md:text-5xl font-bold mb-6 tracking-tight">Features</h2>
                    <div class="space-y-8">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center flex-shrink-0">
                                <i data-lucide="video" class="w-6 h-6 text-blue-400"></i>
                            </div>
                            <div>
                                <h3 class="text-xl font-semibold mb-2">Live Video Status</h3>
                                <p class="text-gray-400 leading-relaxed">Share real-time moments that disappear when the vibe fades. Your life, unfiltered and ephemeral.</p>
                            </div>
                        </div>
                        
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center flex-shrink-0">
                                <i data-lucide="zap" class="w-6 h-6 text-yellow-400"></i>
                            </div>
                            <div>
                                <h3 class="text-xl font-semibold mb-2">Mood-Based Chat</h3>
                                <p class="text-gray-400 leading-relaxed">AI-powered conversations that match your energy. From chill late-night talks to hype morning vibes.</p>
                            </div>
                        </div>
                        
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center flex-shrink-0">
                                <i data-lucide="ghost" class="w-6 h-6 text-purple-400"></i>
                            </div>
                            <div>
                                <h3 class="text-xl font-semibold mb-2">Ghost Mode</h3>
                                <p class="text-gray-400 leading-relaxed">Disappear completely when you need space. No read receipts, no online status, no pressure.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Chat Interface Preview -->
    <section class="py-32 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/[0.02] to-transparent"></div>
        <div class="max-w-5xl mx-auto px-6 relative">
            <div class="glass-panel rounded-[2.5rem] p-8 md:p-12 glow">
                <div class="flex items-center justify-between mb-8">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center">
                            <i data-lucide="bot" class="w-6 h-6 text-white"></i>
                        </div>
                        <div>
                            <div class="font-semibold">AI Assistant</div>
                            <div class="text-sm text-green-400 flex items-center gap-1">
                                <span class="w-1.5 h-1.5 bg-green-400 rounded-full"></span>
                                Smart replies on
                            </div>
                        </div>
                    </div>
                    <button class="glass-panel p-3 rounded-full hover:bg-white/10 transition-colors">
                        <i data-lucide="more-vertical" class="w-5 h-5"></i>
                    </button>
                </div>
                
                <div class="space-y-4 mb-8">
                    <div class="flex gap-4">
                        <div class="w-8 h-8 rounded-full bg-gray-700 flex-shrink-0"></div>
                        <div class="glass-panel rounded-2xl rounded-tl-none px-5 py-3 max-w-[80%]">
                            <p class="text-gray-300">How are you feeling today?</p>
                            <span class="text-xs text-gray-500 mt-1 block">10:30 AM</span>
                        </div>
                    </div>
                    
                    <div class="flex gap-4 justify-end">
                        <div class="bg-white text-black rounded-2xl rounded-tr-none px-5 py-3 max-w-[80%]">
                            <p>That energy is contagious 🔥</p>
                            <span class="text-xs text-gray-500 mt-1 block">10:32 AM</span>
                        </div>
                    </div>
                    
                    <div class="flex items-center gap-2 text-xs text-gray-500 justify-center my-6">
                        <i data-lucide="clock" class="w-3 h-3"></i>
                        Messages auto-delete in 5 minutes
                    </div>
                </div>
                
                <div class="glass-panel rounded-2xl p-4 flex items-center gap-4">
                    <button class="p-2 hover:bg-white/10 rounded-full transition-colors">
                        <i data-lucide="plus" class="w-5 h-5 text-gray-400"></i>
                    </button>
                    <input type="text" placeholder="Message..." class="flex-1 bg-transparent outline-none text-white placeholder-gray-500">
                    <button class="p-2 hover:bg-white/10 rounded-full transition-colors">
                        <i data-lucide="mic" class="w-5 h-5 text-gray-400"></i>
                    </button>
                    <button class="bg-white text-black p-3 rounded-full hover:bg-gray-200 transition-colors">
                        <i data-lucide="send" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Voice Rooms -->
    <section class="py-32">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">Voice Chat Rooms</h2>
                <p class="text-gray-400 text-lg">Drop into conversations that match your vibe</p>
            </div>
            
            <div class="grid md:grid-cols-3 gap-6">
                <div class="glass-panel rounded-3xl p-6 hover:bg-white/5 transition-all cursor-pointer group">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-orange-500 to-red-500 flex items-center justify-center">
                            <i data-lucide="sunset" class="w-6 h-6 text-white"></i>
                        </div>
                        <span class="text-sm text-gray-400 flex items-center gap-1">
                            <span class="w-2 h-2 bg-green-400 rounded-full"></span>
                            12 people
                        </span>
                    </div>
                    <h3 class="text-xl font-semibold mb-2">Late-Night Vibes</h3>
                    <p class="text-gray-400 text-sm mb-4">Chill conversations for the night owls</p>
                    <div class="flex -space-x-2">
                        <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&h=100&fit=crop&crop=face" class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] object-cover">
                        <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=100&h=100&fit=crop&crop=face" class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] object-cover">
                        <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop&crop=face" class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] object-cover">
                        <div class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] bg-white/10 flex items-center justify-center text-xs">+9</div>
                    </div>
                </div>
                
                <div class="glass-panel rounded-3xl p-6 hover:bg-white/5 transition-all cursor-pointer group">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center">
                            <i data-lucide="coffee" class="w-6 h-6 text-white"></i>
                        </div>
                        <span class="text-sm text-gray-400 flex items-center gap-1">
                            <span class="w-2 h-2 bg-green-400 rounded-full"></span>
                            8 people
                        </span>
                    </div>
                    <h3 class="text-xl font-semibold mb-2">Morning Coffee</h3>
                    <p class="text-gray-400 text-sm mb-4">Start your day with good conversation</p>
                    <div class="flex -space-x-2">
                        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face" class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] object-cover">
                        <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&h=100&fit=crop&crop=face" class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] object-cover">
                        <div class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] bg-white/10 flex items-center justify-center text-xs">+6</div>
                    </div>
                </div>
                
                <div class="glass-panel rounded-3xl p-6 hover:bg-white/5 transition-all cursor-pointer group">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center">
                            <i data-lucide="music" class="w-6 h-6 text-white"></i>
                        </div>
                        <span class="text-sm text-gray-400 flex items-center gap-1">
                            <span class="w-2 h-2 bg-green-400 rounded-full"></span>
                            24 people
                        </span>
                    </div>
                    <h3 class="text-xl font-semibold mb-2">Music Discovery</h3>
                    <p class="text-gray-400 text-sm mb-4">Share and find your next favorite track</p>
                    <div class="flex -space-x-2">
                        <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&h=100&fit=crop&crop=face" class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] object-cover">
                        <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=100&h=100&fit=crop&crop=face" class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] object-cover">
                        <img src="https://images.unsplash.com/photo-1517841905240-472988babdf9?w=100&h=100&fit=crop&crop=face" class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] object-cover">
                        <div class="w-8 h-8 rounded-full border-2 border-[#0a0a0a] bg-white/10 flex items-center justify-center text-xs">+21</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Privacy Section -->
    <section id="privacy" class="py-32 relative">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-6 tracking-tight">Your data. Your rules.</h2>
                <p class="text-gray-400 text-lg max-w-2xl mx-auto">
                    Hi-Chat is built with privacy-first defaults: encryption, disappearing messages, and controls that actually put you in charge.
                </p>
            </div>
            
            <div class="glass-panel rounded-[2rem] p-8 md:p-12 max-w-4xl mx-auto">
                <h3 class="text-2xl font-semibold mb-8 flex items-center gap-3">
                    <i data-lucide="shield" class="w-6 h-6 text-green-400"></i>
                    Privacy Dashboard
                </h3>
                
                <div class="space-y-6">
                    <div class="flex items-center justify-between py-4 border-b border-white/10">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center">
                                <i data-lucide="eye" class="w-5 h-5 text-blue-400"></i>
                            </div>
                            <div>
                                <div class="font-medium">Read receipts</div>
                                <div class="text-sm text-gray-400">Let others see when you read</div>
                            </div>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" class="sr-only peer" checked>
                            <div class="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500"></div>
                        </label>
                    </div>
                    
                    <div class="flex items-center justify-between py-4 border-b border-white/10">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center">
                                <i data-lucide="ghost" class="w-5 h-5 text-purple-400"></i>
                            </div>
                            <div>
                                <div class="font-medium">Ghost Mode</div>
                                <div class="text-sm text-gray-400">Hide your online status</div>
                            </div>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" class="sr-only peer">
                            <div class="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-purple-500"></div>
                        </label>
                    </div>
                    
                    <div class="flex items-center justify-between py-4 border-b border-white/10">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center">
                                <i data-lucide="lock" class="w-5 h-5 text-yellow-400"></i>
                            </div>
                            <div>
                                <div class="font-medium">Screen lock</div>
                                <div class="text-sm text-gray-400">Require Face ID to open</div>
                            </div>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" class="sr-only peer" checked>
                            <div class="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-yellow-500"></div>
                        </label>
                    </div>
                    
                    <div class="flex items-center justify-between py-4">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center">
                                <i data-lucide="key" class="w-5 h-5 text-green-400"></i>
                            </div>
                            <div>
                                <div class="font-medium">End-to-End Encrypted</div>
                                <div class="text-sm text-gray-400">Your messages are secure</div>
                            </div>
                        </div>
                        <span class="text-green-400 text-sm font-medium flex items-center gap-1">
                            <i data-lucide="check-circle" class="w-4 h-4"></i>
                            Active
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section id="download" class="py-32 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-t from-white/5 to-transparent"></div>
        <div class="max-w-4xl mx-auto px-6 text-center relative">
            <h2 class="text-4xl md:text-6xl font-black mb-6 tracking-tight">
                Ready to chat like it's<br>
                <span class="gradient-text">3025?</span>
            </h2>
            <p class="text-xl text-gray-400 mb-12">
                Get Hi-Chat. No spam. No noise. Just vibes.
            </p>
            
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
                <button class="bg-white text-black px-8 py-4 rounded-full font-semibold text-lg hover:bg-gray-200 transition-all hover:scale-105 flex items-center gap-3">
                    <i data-lucide="apple" class="w-6 h-6"></i>
                    Download for iOS
                </button>
                <button class="glass-panel px-8 py-4 rounded-full font-semibold text-lg hover:bg-white/10 transition-all flex items-center gap-3">
                    <i data-lucide="smartphone" class="w-6 h-6"></i>
                    Download for Android
                </button>
            </div>
            
            <p class="text-gray-500 text-sm mb-8">Also available on the web.</p>
            
            <div class="inline-flex items-center gap-2 glass-panel px-6 py-3 rounded-full">
